# ============================================
# Voting System - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_NAME=votingnova
DB_USER=root
DB_PASS=RootPass123!

# ============================================
# Advanta SMS/USSD API Configuration
# ============================================
# Get these from your Advanta account dashboard
# https://developers.advantasms.com/

# Your Advanta API Key
ADVANTA_API_KEY=a0141970388cbca1a9cf86cab3a12e8e

# Your Advanta Partner ID
ADVANTA_PARTNER_ID=15762

# Your Advanta Shortcode
ADVANTA_SHORTCODE=SchoolSMS

# USSD Callback URL - Your server endpoint that receives USSD requests
# Live domain: voting.novotechafrica.co.ke
ADVANTA_USSD_CALLBACK_URL=https://voting.novotechafrica.co.ke/api/ussd.php

# ============================================
# M-Pesa Daraja API Configuration
# ============================================
# Get these from Safaricom Developer Portal
# https://developer.safaricom.co.ke/

# Environment: 'sandbox' for testing, 'production' for live
MPESA_ENV=production

# M-Pesa Consumer Key
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here

# M-Pesa Consumer Secret
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here

# M-Pesa Business Shortcode (Paybill or Till Number)
MPESA_SHORTCODE=your_mpesa_shortcode_here

# M-Pesa Passkey (Lipa Na M-Pesa Online Passkey)
MPESA_PASSKEY=your_mpesa_passkey_here

# M-Pesa Callback URL - Your server endpoint that receives payment callbacks
# Note: This system uses C2B (Customer to Business) only via STK Push
# Live domain: voting.novotechafrica.co.ke
MPESA_CALLBACK_URL=https://voting.novotechafrica.co.ke/api/mpesa-callback.php

# ============================================
# STK Push / Mobile Money – which provider to use
# ============================================
# Set to 'paystack' to use Paystack; 'mpesa' or leave empty to use M-Pesa Daraja
PAYMENT_PROVIDER=mpesa

# ============================================
# Paystack (when PAYMENT_PROVIDER=paystack)
# ============================================
# From Paystack Dashboard → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here
# Webhook secret – use the SAME value as PAYSTACK_SECRET_KEY (sk_live_...). Paystack signs webhooks with your secret key. Do NOT put the webhook URL here.
PAYSTACK_WEBHOOK_SECRET=sk_live_your_secret_key_here
# Email for Charge API (optional; default: vote@votingnova.app). Use a valid format if Paystack rejects.
# PAYSTACK_CHARGE_EMAIL=vote@yourdomain.com

# ============================================
# USSD Base Code Configuration
# ============================================
# The USSD code users will dial (e.g., *519*24#)
# This should match your Advanta shortcode configuration
USSD_BASE_CODE=*519*24#

# ============================================
# Admin Login Credentials
# ============================================
# Default admin username and password
# IMPORTANT: Change these after first login!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============================================
# Application Configuration
# ============================================
# Application base URL (for generating absolute URLs)
# Live domain: voting.novotechafrica.co.ke
APP_URL=https://voting.novotechafrica.co.ke

# Application environment: 'development' or 'production'
APP_ENV=development

# Enable/disable debug mode (set to 'false' in production)
APP_DEBUG=true
